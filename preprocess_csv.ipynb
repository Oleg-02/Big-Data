
# Read just the header line
with open('games.csv', 'r', encoding='utf-8') as f:
    header = f.readline()

print("Current header:", header)

# Fix the header by replacing 'DiscountDLC count' with 'Discount,DLC count'
fixed_header = header.replace('DiscountDLC count', 'Discount,DLC count')

print("Fixed header:", fixed_header)

# Read all lines
with open('games.csv', 'r', encoding='utf-8') as f:
    lines = f.readlines()

# Replace the first line with the fixed header
lines[0] = fixed_header

# Write back to a new file (or overwrite)
with open('games.csv', 'w', encoding='utf-8') as f:
    f.writelines(lines)

